{
  "name": "starlights",
  "private": true,
  "workspaces": [
    "packages/ui",
    "packages/ui-framework",
    "apps/landing-page",
    "apps/builder-app",
    "apps/content-manager",
    "apps/showcase"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/builder-app",
    "content": "npm run dev -w apps/content-manager",
    "landing": "npm run dev -w apps/landing-page",
    "showcase": "npm run dev -w apps/showcase",
    "build:packages": "npm run build -w packages/ui-framework",
    "build:apps": "npm run build -w apps/builder-app && npm run build -w apps/showcase && npm run build -w apps/landing-page && npm run build -w apps/content-manager",
    "build": "npm run build:packages && npm run build:apps",
    "lint": "npm run lint -w apps/builder-app",
    "preview": "npm run preview -w apps/builder-app"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "lucide-react": "^1.8.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
